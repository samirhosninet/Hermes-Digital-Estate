{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-agent.local/schemas/runtime-guard-decision-v1.json",
  "title": "Hermes Runtime Guard Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision",
    "boundary",
    "risk_class",
    "reason",
    "policy_version"
  ],
  "properties": {
    "schema_version": {
      "const": "runtime-guard-decision-v1"
    },
    "decision": {
      "enum": [
        "allow",
        "deny",
        "escalate",
        "fail_closed"
      ]
    },
    "boundary": {
      "enum": [
        "terminal",
        "file",
        "package",
        "git",
        "network",
        "credentials",
        "model_routing",
        "gateway",
        "cron_webhook",
        "unknown"
      ]
    },
    "risk_class": {
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3",
        "R4",
        "R5",
        "unknown"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "matched_rule_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "requires_operator_approval": {
      "type": "boolean"
    },
    "redacted_action_summary": {
      "type": "string"
    }
  }
}
