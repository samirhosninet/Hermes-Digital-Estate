{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-agent.local/schemas/runtime-guard-audit-record-v1.json",
  "title": "Hermes Runtime Guard Audit Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "timestamp_utc",
    "boundary",
    "risk_class",
    "decision",
    "actor",
    "policy_version",
    "action_hash",
    "redacted_action_summary"
  ],
  "properties": {
    "schema_version": {
      "const": "runtime-guard-audit-record-v1"
    },
    "timestamp_utc": {
      "type": "string",
      "minLength": 1
    },
    "boundary": {
      "enum": [
        "terminal",
        "file",
        "package",
        "git",
        "network",
        "credentials",
        "model_routing",
        "gateway",
        "cron_webhook",
        "unknown"
      ]
    },
    "risk_class": {
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3",
        "R4",
        "R5",
        "unknown"
      ]
    },
    "decision": {
      "enum": [
        "allow",
        "deny",
        "escalate",
        "fail_closed"
      ]
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "matched_rule_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "action_hash": {
      "type": "string",
      "minLength": 8
    },
    "redacted_action_summary": {
      "type": "string",
      "minLength": 1
    },
    "secret_redaction_applied": {
      "type": "boolean"
    },
    "approval_reference": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
