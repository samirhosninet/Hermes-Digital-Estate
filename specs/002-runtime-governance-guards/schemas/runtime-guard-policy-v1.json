{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-agent.local/schemas/runtime-guard-policy-v1.json",
  "title": "Hermes Runtime Guard Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "mode",
    "portable",
    "default_decision",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "const": "runtime-guard-policy-v1"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": ["design_only", "dry_run", "strict"]
    },
    "portable": {
      "type": "boolean"
    },
    "default_decision": {
      "enum": ["deny", "escalate", "fail_closed"]
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "boundary", "risk_class", "decision", "match", "reason"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "boundary": {
            "enum": ["terminal", "file", "package", "git", "network", "credentials", "model_routing", "gateway", "cron_webhook"]
          },
          "risk_class": {
            "enum": ["R0", "R1", "R2", "R3", "R4", "R5"]
          },
          "decision": {
            "enum": ["allow", "deny", "escalate", "fail_closed"]
          },
          "match": {
            "type": "object",
            "additionalProperties": true
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
