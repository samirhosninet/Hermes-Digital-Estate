{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Log-Only Implementation Gate v1",
  "type": "object",
  "required": [
    "schema_version",
    "mode",
    "runtime_enforcement_enabled",
    "may_block_commands",
    "changes_terminal_execution_flow",
    "default_failure_behavior",
    "required_evidence_before_runtime_touchpoint",
    "runtime_touchpoint_constraints",
    "rollback"
  ],
  "properties": {
    "schema_version": {"const": "log-only-implementation-gate-v1"},
    "mode": {"const": "log_only"},
    "runtime_enforcement_enabled": {"const": false},
    "may_block_commands": {"const": false},
    "changes_terminal_execution_flow": {"const": false},
    "default_failure_behavior": {"const": "continue_without_governance_block"},
    "required_evidence_before_runtime_touchpoint": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "runtime_touchpoint_constraints": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "rollback": {"type": "string"}
  },
  "additionalProperties": false
}
