{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hermes Digital State Profile Distribution Contract",
  "type": "object",
  "required": ["name", "version", "description", "hermes_requires", "env_requires", "distribution_owned"],
  "properties": {
    "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "version": {"type": "string"},
    "description": {"type": "string"},
    "hermes_requires": {"type": "string"},
    "author": {"type": "string"},
    "license": {"type": "string"},
    "env_requires": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "required"],
        "properties": {
          "name": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
          "description": {"type": "string"},
          "required": {"type": "boolean"},
          "default": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "distribution_owned": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
