{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Digital State Model Ministry Routing v1",
  "type": "object",
  "required": [
    "schema_version",
    "fallback_enabled",
    "routing_policy",
    "ministries",
    "reserve_models",
    "test_policy"
  ],
  "properties": {
    "schema_version": {"const": "model-ministry-routing-v1"},
    "fallback_enabled": {"const": false},
    "routing_policy": {
      "type": "string",
      "enum": ["fixed_ministry_model_assignments"]
    },
    "ministries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "provider", "model", "purpose", "launch_critical", "timeout_seconds", "health_status"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "provider": {"type": "string", "minLength": 1},
          "model": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "launch_critical": {"type": "boolean"},
          "timeout_seconds": {"type": "integer", "minimum": 1},
          "health_status": {
            "type": "string",
            "enum": ["healthy", "slow_healthy", "experimental", "not_launch_ready"]
          },
          "notes": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "reserve_models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["model", "status", "assigned_to_ministry", "reason"],
        "properties": {
          "model": {"type": "string"},
          "status": {"type": "string"},
          "assigned_to_ministry": {"type": "boolean"},
          "reason": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "test_policy": {
      "type": "object",
      "required": ["pre_github_release", "pass_condition"],
      "properties": {
        "pre_github_release": {"type": "string"},
        "pass_condition": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
