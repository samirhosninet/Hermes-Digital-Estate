# Digital State Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Required: At least one provider API key
# PROVIDER_NVIDIA_KEY=your-nvidia-nim-api-key-here
# PROVIDER_OPENROUTER_KEY=your-openrouter-key-here
# PROVIDER_ANTHROPIC_KEY=your-anthropic-key-here

# Optional: Voice features
# PROVIDER_VOICE_OPENAI_KEY=your-openai-compatible-key-here
